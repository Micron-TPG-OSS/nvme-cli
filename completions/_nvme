			else
				noeq_opts+=("$opt")
			fi
		done

		(( ${#noeq_opts} )) && _describe -t options "$desc" noeq_opts
		(( ${#eq_opts} )) && _describe -t eq-options "$desc" eq_opts -S ''
	}

