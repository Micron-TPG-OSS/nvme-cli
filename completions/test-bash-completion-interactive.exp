#!/usr/bin/expect -f
# Interactive test for bash completion insertion behavior
#
# PURPOSE:
# Unit tests (like test-bash-completion.sh) can verify what completions are
# OFFERED, but cannot test how text is actually INSERTED into the command line.
# This expect-based test spawns real bash sessions and simulates TAB presses
# to verify the actual insertion behavior, catching issues like unwanted spaces.
#
# WHAT IT TESTS:
# 1. Options ending with "=" (e.g., --timeout=) should not get a trailing space
# 2. Value completion after "=" should not insert a space before the value
#
# WHY IT EXISTS:
# These tests were created to debug and verify fixes for space-related issues
# in bash completion. They confirmed that "compopt -o nospace" is necessary
# to prevent trailing spaces after options like "--timeout=".
#
# NOT RUN BY MESON:
# This test is NOT integrated into "meson test" because it requires the
# "expect" package, which is not a standard dependency. Run manually when
# modifying completion logic.
#
# Requires: expect (install with: apt install expect)
# Usage: ./completions/test-bash-completion-interactive.exp

set timeout 5

# Colors for output
set RED "\033\[0;31m"
set GREEN "\033\[0;32m"
set NC "\033\[0m"

set tests_run 0
set tests_passed 0
set tests_failed 0

# Test completion by sending command + TAB, then using Ctrl-A, Ctrl-K, echo, Ctrl-Y
# to capture and display what the completed line looks like
proc test_completion_line {description send_before_tab expected_pattern} {
    global tests_run tests_passed tests_failed RED GREEN NC

    incr tests_run
    puts ""
    puts "TEST $tests_run: $description"
    puts "  Input: '$send_before_tab<TAB>'"
    puts "  Expected pattern: '$expected_pattern'"

    # Start a fresh bash with completion loaded
    spawn bash --norc --noprofile
    expect -re {\$ $}

    # Source bash-completion first (provides _init_completion)
    send "source /usr/share/bash-completion/bash_completion 2>/dev/null || source /etc/bash_completion 2>/dev/null\r"
    expect -re {\$ $}

    # Source the completion file
    send "source completions/bash-nvme-completion.sh\r"
    expect -re {\$ $}

    # Send the partial command
    send $send_before_tab

    # Send TAB to trigger completion
    send "\t"
    sleep 0.5

    # Now capture the line: Ctrl-A (start), Ctrl-K (kill), then echo + Ctrl-Y (yank)
    # Ctrl-A = \x01, Ctrl-K = \x0b, Ctrl-Y = \x19
    send "\x01\x0b"
    sleep 0.1
    send "echo '"
    send "\x19"
    send "'\r"

    expect {
        -re $expected_pattern {
            puts "  ${GREEN}PASS${NC}"
            incr tests_passed
        }
        timeout {
            puts "  ${RED}FAIL${NC}: Timeout or pattern not found"
            incr tests_failed
        }
    }

    send "exit\r"
    expect eof
}

puts "========================================"
puts "Interactive Bash Completion Tests"
puts "(using expect to test actual insertion)"
puts "========================================"

# Test Issue 1: Trailing space after option completion
# --tim<TAB> should complete to --timeout= without trailing space
# (Using --tim because it uniquely matches --timeout=)
# Pattern looks for = followed immediately by newline (no space)
test_completion_line \
    "Issue 1: --tim<TAB> should complete to --timeout= without trailing space" \
    "nvme feat power-meas --tim" \
    "nvme feat power-meas --timeout=\r"

# Test Issue 2: Space before value after =
# --output-format=j<TAB> should give --output-format=json (no space before json)
# NOTE: A trailing space IS expected here since the value is complete
test_completion_line \
    "Issue 2: --output-format=j<TAB> should complete without space before value" \
    "nvme feat power-meas --output-format=j" \
    "nvme feat power-meas --output-format=json"

# Test: --sel=0<TAB> should stay as --sel=0 (already complete)
# NOTE: A trailing space IS expected here since the value is complete
test_completion_line \
    "Issue 2 variant: --sel=0<TAB> should complete without extra space" \
    "nvme feat power-meas --sel=0" \
    "nvme feat power-meas --sel=0"

# Test space-separated form works too
# NOTE: A trailing space IS expected here since the value is complete
test_completion_line \
    "Space form: --output-format j<TAB> should complete to json" \
    "nvme feat power-meas --output-format j" \
    "nvme feat power-meas --output-format json"

puts ""
puts "========================================"
puts "Results: $tests_passed/$tests_run passed"
if {$tests_failed > 0} {
    puts "${RED}$tests_failed tests failed${NC}"
    exit 1
} else {
    puts "${GREEN}All tests passed${NC}"
    exit 0
}
